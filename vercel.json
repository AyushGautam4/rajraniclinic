{
  "buildCommand": "cd frontend && npm run build",
  "devCommand": "cd frontend && npm start",
  "installCommand": "npm install && cd frontend && npm install",
  "outputDirectory": "frontend/build",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": [
    "RESEND_API_KEY",
    "RESEND_FROM_EMAIL",
    "CONTACT_TO_EMAIL"
  ]
}
